{
  "name": "danielbrain",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/service"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "migrate": "tsx scripts/migrate.ts",
    "build": "npm run build --workspaces",
    "dev": "tsx watch packages/service/src/index.ts"
  },
  "devDependencies": {
    "@types/multer": "^2.1.0",
    "@types/supertest": "^7.2.0",
    "dotenv": "^16.4.0",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "file-type": "^21.3.3",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "pdf-parse": "^1.1.1"
  }
}
