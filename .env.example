# Database (local PostgreSQL)
DATABASE_URL=postgresql://danielbrain:changeme@localhost:5432/danielbrain
POSTGRES_PASSWORD=changeme

# Slack
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_SIGNING_SECRET=your-signing-secret

# Telegram (optional)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# SerpAPI (optional — for LinkedIn enrichment)
SERPAPI_KEY=your-serpapi-key

# Fathom (optional — for meeting transcript ingestion)
FATHOM_API_KEY=your-fathom-api-key
FATHOM_WEBHOOK_SECRET=whsec_your-webhook-secret

# Security
BRAIN_ACCESS_KEY=your-64-char-hex-key

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
EXTRACTION_MODEL=llama3.3:70b
CHAT_MODEL=llama3.3:70b
RELATIONSHIP_MODEL=llama3.3:70b

# File storage
RAW_FILES_DIR=./data/raw-files
TRANSCRIBE_DIR=./data/transcriptions

# Whisper (audio transcription via faster-whisper-server)
WHISPER_BASE_URL=http://localhost:8001
WHISPER_MODEL=large-v3

# Service
MCP_PORT=3000
POLL_INTERVAL_MS=5000
BATCH_SIZE=5
MAX_RETRIES=3
